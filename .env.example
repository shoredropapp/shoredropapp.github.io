# Public client keys only — same Supabase project + Stripe account as the Cap app.
# Copy to .env.local for local `npm run dev` / `npm run build`.
# Production: set the same three names as GitHub Actions secrets (Settings → Secrets → Actions).
#
# Never put STRIPE_SECRET_KEY here. That stays in Supabase Edge Function secrets only.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Match Edge STRIPE_SECRET_KEY mode (pk_live_ with sk_live_, or pk_test_ with sk_test_)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
